# Server Environment Variables
# Copia este archivo a .env y modifica los valores

# Puerto del servidor
SERVER_PORT=3000

# UPS Configuration
UPS_NAME=ups
NUT_UPS_HOST=localhost
NUT_UPS_PORT=3493

# Monitoreo
POLL_INTERVAL=5000
POWER_LOST_THRESHOLD=2
LOW_BATTERY_THRESHOLD=20

# Modo desarrollo (sin UPS física)
MOCK_MODE=false